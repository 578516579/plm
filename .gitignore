# Claude Code session data — ignore everything under .claude/ EXCEPT shared rule/playbook files
.claude/*
!.claude/*.md
!.claude/settings.json
!.claude/agents/
.claude/agents/*
!.claude/agents/*.md
!.claude/skills/
!.claude/skills/**
!.claude/commands/
!.claude/commands/**
# Notes:
#   settings.json       → shared (team-wide hooks/policies, in git)
#   settings.local.json → user-specific permissions cache, stays ignored
#   agents/*.md         → shared subagent configs (team can invoke)
#   skills/, commands/  → shared (team-wide Claude playbooks/slash-commands, in git)

# Environment files with secrets
.env
.env.local
*.env.local

# OS / Editor
.DS_Store
Thumbs.db
*.swp
*~

# IDE (root-level fallback; subprojects have their own)
.idea/
.vscode/
