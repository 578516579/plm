# =============================================================================
# PLM 后端 - 环境变量样例（生产部署务必复制为 .env 或通过容器/CI 注入）
# =============================================================================
# Spring Boot 默认不读 .env 文件本身，本文件仅作"必需变量清单"文档。
# 实际注入方式（任选其一）：
#   1) IDE 运行配置 → Environment Variables 中粘贴
#   2) shell：export DB_PASSWORD=xxx && java -jar plm-admin.jar
#   3) docker-compose：services.<svc>.env_file: ./.env
#   4) Kubernetes：ConfigMap / Secret 挂到容器 env
# =============================================================================

# --- JWT 令牌 ---
# 生产环境必须替换为不少于 32 字符的强随机值，例如 `openssl rand -base64 48`
JWT_SECRET=please-change-me-to-a-strong-random-secret
# 令牌有效期（分钟），默认 30
JWT_EXPIRE_MINUTES=30

# --- MySQL 主库 ---
DB_URL=jdbc:mysql://localhost:3306/plm?useUnicode=true&characterEncoding=utf8&zeroDateTimeBehavior=convertToNull&useSSL=true&serverTimezone=GMT%2B8
DB_USERNAME=root
DB_PASSWORD=please-change-me

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=

# --- Druid 监控台（/druid）---
# 生产环境强烈建议关闭或换强口令
DRUID_USERNAME=plm
DRUID_PASSWORD=please-change-me

# =============================================================================
# MCP / 集成对接 (plm-mcp + plm-integration, Proposal 0007)
# =============================================================================

# --- MCP/Integration 凭据加密 key (必填) ---
# AES-256-GCM 密钥，长度必须是 base64 编码后 44 字符 (32 字节原始)。
# 生成命令: openssl rand -base64 32
# ⚠ 启动期会校验：保留默认值 "please-change-me" 则后端拒绝启动 (errorCode=809)
MCP_ENCRYPT_KEY=please-change-me-44chars-base64-AAAAAAAAAAAAAA=
MCP_ENCRYPT_KEY_VERSION=v1

# --- MCP Server (本系统对外暴露的 MCP 端点) ---
# OAuth issuer，留 Phase 2；本期 Phase 1 用长效 token
MCP_OAUTH_ISSUER=
# tools/call 单次调用超时 (ms)
MCP_TOOL_TIMEOUT_MS=30000

# --- 飞书 (Feishu / Lark) sandbox 凭据 ---
# 从 https://open.feishu.cn → 应用管理 → 凭证与基础信息 拿到 app_id / app_secret
# verification_token 在「事件订阅」中查看
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
# 事件加密 key (如开启了「加密推送」)，否则留空
FEISHU_ENCRYPT_KEY=
# 飞书 OpenAPI 基址 (默认值通常不动)
FEISHU_OPENAPI_BASE=https://open.feishu.cn/open-apis

# --- GitLab sandbox 凭据 ---
# GitLab 实例地址 (例 https://gitlab.com 或自建 https://gitlab.your-domain.com)
GITLAB_URL=https://gitlab.com
# Personal Access Token, scopes: api, read_repository, write_repository
GITLAB_TOKEN=
# Webhook 回调签名密钥 (任意强随机字符串，配置在 GitLab project webhooks 的 Secret Token 字段)
GITLAB_WEBHOOK_SECRET=
