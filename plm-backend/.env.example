# =============================================================================
# PLM 后端 - 环境变量样例（生产部署务必复制为 .env 或通过容器/CI 注入）
# =============================================================================
# Spring Boot 默认不读 .env 文件本身，本文件仅作"必需变量清单"文档。
# 实际注入方式（任选其一）：
#   1) IDE 运行配置 → Environment Variables 中粘贴
#   2) shell：export DB_PASSWORD=xxx && java -jar plm-admin.jar
#   3) docker-compose：services.<svc>.env_file: ./.env
#   4) Kubernetes：ConfigMap / Secret 挂到容器 env
# =============================================================================

# --- JWT 令牌 ---
# 生产环境必须替换为不少于 32 字符的强随机值，例如 `openssl rand -base64 48`
JWT_SECRET=please-change-me-to-a-strong-random-secret
# 令牌有效期（分钟），默认 30
JWT_EXPIRE_MINUTES=30

# --- MySQL 主库 ---
DB_URL=jdbc:mysql://localhost:3306/plm?useUnicode=true&characterEncoding=utf8&zeroDateTimeBehavior=convertToNull&useSSL=true&serverTimezone=GMT%2B8
DB_USERNAME=root
DB_PASSWORD=please-change-me

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=

# --- Druid 监控台（/druid）---
# 生产环境强烈建议关闭或换强口令
DRUID_USERNAME=plm
DRUID_PASSWORD=please-change-me

# --- Dify AI 编排 (PRD §2.3) ---
# 总开关:false → 全部走 mock(默认,保护本地零依赖与 CI 稳定)
# 生产开启:DIFY_ENABLED=true 且 DIFY_API_KEY=<Dify Service API Key,Bearer>
DIFY_ENABLED=false
DIFY_BASE_URL=https://api.dify.ai/v1
DIFY_API_KEY=
DIFY_CONNECT_TIMEOUT_MS=5000
DIFY_READ_TIMEOUT_MS=60000
DIFY_DEFAULT_USER=plm-system
# 19 个 PRD workflow 中先映射 6 类核心 Agent;tb_ai_agent.dify_workflow_id 可覆盖
DIFY_WF_REQUIREMENT=
DIFY_WF_PRD=
DIFY_WF_CODE=
DIFY_WF_TEST=
DIFY_WF_RELEASE=
DIFY_WF_OPS=
