<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.com.bosssfot.dv.plm.aiagent.invocationlog.mapper.AiInvocationLogMapper">
    <resultMap type="cn.com.bosssfot.dv.plm.aiagent.invocationlog.domain.AiInvocationLog" id="AiInvocationLogResult">
        <id     property="logId"            column="log_id"            />
        <result property="callerTag"        column="caller_tag"        />
        <result property="provider"         column="provider"          />
        <result property="model"            column="model"             />
        <result property="success"          column="success"           />
        <result property="finishReason"     column="finish_reason"     />
        <result property="promptTokens"     column="prompt_tokens"     />
        <result property="completionTokens" column="completion_tokens" />
        <result property="totalTokens"      column="total_tokens"      />
        <result property="elapsedMs"        column="elapsed_ms"        />
        <result property="requestId"        column="request_id"        />
        <result property="errorMsg"         column="error_msg"         />
        <result property="invokedAt"        column="invoked_at"        />
    </resultMap>

    <sql id="vo">
        select log_id, caller_tag, provider, model, success, finish_reason,
               prompt_tokens, completion_tokens, total_tokens, elapsed_ms,
               request_id, error_msg, invoked_at
        from tb_ai_invocation_log
    </sql>

    <insert id="insertAiInvocationLog" parameterType="cn.com.bosssfot.dv.plm.aiagent.invocationlog.domain.AiInvocationLog" useGeneratedKeys="true" keyProperty="logId">
        insert into tb_ai_invocation_log
        (caller_tag, provider, model, success, finish_reason,
         prompt_tokens, completion_tokens, total_tokens, elapsed_ms,
         request_id, error_msg, invoked_at)
        values
        (#{callerTag}, #{provider}, #{model}, #{success}, #{finishReason},
         #{promptTokens}, #{completionTokens}, #{totalTokens}, #{elapsedMs},
         #{requestId}, #{errorMsg}, #{invokedAt})
    </insert>

    <select id="selectAiInvocationLogList" parameterType="cn.com.bosssfot.dv.plm.aiagent.invocationlog.domain.AiInvocationLog" resultMap="AiInvocationLogResult">
        <include refid="vo"/>
        <where>
            <if test="callerTag != null and callerTag != ''">and caller_tag like concat('%', #{callerTag}, '%')</if>
            <if test="provider != null and provider != ''">and provider = #{provider}</if>
            <if test="success != null">and success = #{success}</if>
        </where>
        order by invoked_at desc, log_id desc
    </select>

    <select id="selectAiInvocationLogById" parameterType="Long" resultMap="AiInvocationLogResult">
        <include refid="vo"/>
        where log_id = #{logId}
    </select>

    <delete id="deleteAiInvocationLogByIds" parameterType="Long">
        delete from tb_ai_invocation_log where log_id in
        <foreach item="id" collection="array" open="(" separator="," close=")">#{id}</foreach>
    </delete>

    <select id="selectProviderSummary" resultType="java.util.HashMap">
        select provider,
               count(*)               as total,
               sum(success)           as success_count,
               sum(total_tokens)      as total_tokens,
               round(avg(elapsed_ms)) as avg_elapsed_ms,
               round(sum(success) * 100 / count(*), 2) as success_rate
        from tb_ai_invocation_log
        group by provider
        order by total desc
    </select>
</mapper>
