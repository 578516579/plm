<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.com.bosssfot.dv.plm.analytics.mapper.AnalyticsMapper">

    <resultMap type="Analytics" id="AnalyticsResult">
        <result property="analyticsId"             column="analytics_id"              />
        <result property="analyticsNo"             column="analytics_no"              />
        <result property="projectId"               column="project_id"                />
        <result property="title"                   column="title"                     />
        <result property="period"                  column="period"                    />
        <result property="periodValue"             column="period_value"              />
        <result property="requirementThroughput"   column="requirement_throughput"    />
        <result property="iterationOnTimeRate"     column="iteration_on_time_rate"    />
        <result property="defectDensity"           column="defect_density"            />
        <result property="aiTimeSaved"             column="ai_time_saved"             />
        <result property="projectHealthScore"      column="project_health_score"      />
        <result property="aiSuggestions"           column="ai_suggestions"            />
        <result property="aiGenerated"             column="ai_generated"              />
        <result property="aiGeneratedAt"           column="ai_generated_at"           />
        <result property="status"                  column="status"                    />
        <result property="authorUserId"            column="author_user_id"            />
        <result property="createBy"                column="create_by"                 />
        <result property="createTime"              column="create_time"               />
        <result property="updateBy"                column="update_by"                 />
        <result property="updateTime"              column="update_time"               />
        <result property="remark"                  column="remark"                    />
        <result property="delFlag"                 column="del_flag"                  />
    </resultMap>

    <sql id="selectAnalyticsVo">
        select analytics_id, analytics_no, project_id, title, period, period_value,
               requirement_throughput, iteration_on_time_rate, defect_density,
               ai_time_saved, project_health_score, ai_suggestions, ai_generated,
               ai_generated_at, status, author_user_id,
               create_by, create_time, update_by, update_time, remark, del_flag
        from tb_analytics
    </sql>

    <select id="selectAnalyticsList" parameterType="Analytics" resultMap="AnalyticsResult">
        <include refid="selectAnalyticsVo"/>
        <where>
            del_flag = '0'
            <if test="analyticsNo != null and analyticsNo != ''">and analytics_no like concat('%', #{analyticsNo}, '%')</if>
            <if test="projectId != null">and project_id = #{projectId}</if>
            <if test="title != null and title != ''">and title like concat('%', #{title}, '%')</if>
            <if test="period != null and period != ''">and period = #{period}</if>
            <if test="periodValue != null and periodValue != ''">and period_value = #{periodValue}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
            <if test="authorUserId != null">and author_user_id = #{authorUserId}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectAnalyticsById" parameterType="Long" resultMap="AnalyticsResult">
        <include refid="selectAnalyticsVo"/>
        where analytics_id = #{analyticsId} and del_flag = '0'
    </select>

    <insert id="insertAnalytics" parameterType="Analytics" useGeneratedKeys="true" keyProperty="analyticsId">
        insert into tb_analytics
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="analyticsNo != null">analytics_no,</if>
            <if test="projectId != null">project_id,</if>
            <if test="title != null">title,</if>
            <if test="period != null">period,</if>
            <if test="periodValue != null">period_value,</if>
            <if test="requirementThroughput != null">requirement_throughput,</if>
            <if test="iterationOnTimeRate != null">iteration_on_time_rate,</if>
            <if test="defectDensity != null">defect_density,</if>
            <if test="aiTimeSaved != null">ai_time_saved,</if>
            <if test="projectHealthScore != null">project_health_score,</if>
            <if test="aiSuggestions != null">ai_suggestions,</if>
            <if test="aiGenerated != null">ai_generated,</if>
            <if test="aiGeneratedAt != null">ai_generated_at,</if>
            <if test="status != null">status,</if>
            <if test="authorUserId != null">author_user_id,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            del_flag,
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="analyticsNo != null">#{analyticsNo},</if>
            <if test="projectId != null">#{projectId},</if>
            <if test="title != null">#{title},</if>
            <if test="period != null">#{period},</if>
            <if test="periodValue != null">#{periodValue},</if>
            <if test="requirementThroughput != null">#{requirementThroughput},</if>
            <if test="iterationOnTimeRate != null">#{iterationOnTimeRate},</if>
            <if test="defectDensity != null">#{defectDensity},</if>
            <if test="aiTimeSaved != null">#{aiTimeSaved},</if>
            <if test="projectHealthScore != null">#{projectHealthScore},</if>
            <if test="aiSuggestions != null">#{aiSuggestions},</if>
            <if test="aiGenerated != null">#{aiGenerated},</if>
            <if test="aiGeneratedAt != null">#{aiGeneratedAt},</if>
            <if test="status != null">#{status},</if>
            <if test="authorUserId != null">#{authorUserId},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            '0',
            sysdate()
        </trim>
    </insert>

    <update id="updateAnalytics" parameterType="Analytics">
        update tb_analytics
        <trim prefix="SET" suffixOverrides=",">
            <if test="analyticsNo != null">analytics_no = #{analyticsNo},</if>
            <if test="projectId != null">project_id = #{projectId},</if>
            <if test="title != null">title = #{title},</if>
            <if test="period != null">period = #{period},</if>
            <if test="periodValue != null">period_value = #{periodValue},</if>
            <if test="requirementThroughput != null">requirement_throughput = #{requirementThroughput},</if>
            <if test="iterationOnTimeRate != null">iteration_on_time_rate = #{iterationOnTimeRate},</if>
            <if test="defectDensity != null">defect_density = #{defectDensity},</if>
            <if test="aiTimeSaved != null">ai_time_saved = #{aiTimeSaved},</if>
            <if test="projectHealthScore != null">project_health_score = #{projectHealthScore},</if>
            <if test="aiSuggestions != null">ai_suggestions = #{aiSuggestions},</if>
            <if test="aiGenerated != null">ai_generated = #{aiGenerated},</if>
            <if test="aiGeneratedAt != null">ai_generated_at = #{aiGeneratedAt},</if>
            <if test="status != null">status = #{status},</if>
            <if test="authorUserId != null">author_user_id = #{authorUserId},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where analytics_id = #{analyticsId}
    </update>

    <update id="deleteAnalyticsByIds" parameterType="Long">
        update tb_analytics set del_flag = '2' where analytics_id in
        <foreach item="analyticsId" collection="array" open="(" separator="," close=")">
            #{analyticsId}
        </foreach>
    </update>

    <select id="selectMaxSeqOfYear" parameterType="String" resultType="java.lang.Integer">
        select max(cast(substring(analytics_no, length(#{prefix}) + 1) as unsigned)) as max_seq
        from tb_analytics
        where analytics_no like concat(#{prefix}, '%')
    </select>

</mapper>
