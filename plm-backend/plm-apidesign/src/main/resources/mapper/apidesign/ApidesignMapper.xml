<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.com.bosssfot.dv.plm.apidesign.mapper.ApidesignMapper">

    <resultMap type="cn.com.bosssfot.dv.plm.apidesign.domain.Apidesign" id="ApidesignResult">
        <id     property="apidesignId"     column="apidesign_id"/>
        <result property="apidesignNo"     column="apidesign_no"/>
        <result property="projectId"       column="project_id"/>
        <result property="title"           column="title"/>
        <result property="httpMethod"      column="http_method"/>
        <result property="apiPath"         column="api_path"/>
        <result property="description"     column="description"/>
        <result property="requestSchema"   column="request_schema"/>
        <result property="responseSchema"  column="response_schema"/>
        <result property="errorCodes"      column="error_codes"/>
        <result property="openapiContent"  column="openapi_content"/>
        <result property="mockEnabled"     column="mock_enabled"/>
        <result property="version"         column="version"/>
        <result property="reviewReport"    column="review_report"/>
        <result property="aiGenerated"     column="ai_generated"/>
        <result property="aiGeneratedAt"   column="ai_generated_at"/>
        <result property="status"          column="status"/>
        <result property="authorUserId"    column="author_user_id"/>
        <result property="reviewerUserId"  column="reviewer_user_id"/>
        <result property="createBy"        column="create_by"/>
        <result property="createTime"      column="create_time"/>
        <result property="updateBy"        column="update_by"/>
        <result property="updateTime"      column="update_time"/>
        <result property="remark"          column="remark"/>
    </resultMap>

    <sql id="selectApidesignVo">
        SELECT apidesign_id, apidesign_no, project_id, title, http_method, api_path,
               description, request_schema, response_schema, error_codes, openapi_content,
               mock_enabled, version, review_report, ai_generated, ai_generated_at,
               status, author_user_id, reviewer_user_id,
               create_by, create_time, update_by, update_time, remark
        FROM tb_apidesign
        WHERE del_flag = '0'
    </sql>

    <select id="selectApidesignList" parameterType="cn.com.bosssfot.dv.plm.apidesign.domain.Apidesign" resultMap="ApidesignResult">
        <include refid="selectApidesignVo"/>
        <if test="apidesignNo != null and apidesignNo != ''">AND apidesign_no LIKE CONCAT('%', #{apidesignNo}, '%')</if>
        <if test="projectId != null">AND project_id = #{projectId}</if>
        <if test="title != null and title != ''">AND title LIKE CONCAT('%', #{title}, '%')</if>
        <if test="httpMethod != null and httpMethod != ''">AND http_method = #{httpMethod}</if>
        <if test="status != null and status != ''">AND status = #{status}</if>
        ORDER BY create_time DESC
    </select>

    <select id="selectApidesignById" parameterType="Long" resultMap="ApidesignResult">
        <include refid="selectApidesignVo"/>
        AND apidesign_id = #{apidesignId}
    </select>

    <select id="selectMaxSeqOfYear" parameterType="String" resultType="Integer">
        SELECT MAX(CAST(SUBSTRING_INDEX(apidesign_no, '-', -1) AS UNSIGNED))
        FROM tb_apidesign
        WHERE apidesign_no LIKE CONCAT(#{prefix}, '%') AND del_flag = '0'
    </select>

    <insert id="insertApidesign" parameterType="cn.com.bosssfot.dv.plm.apidesign.domain.Apidesign" useGeneratedKeys="true" keyProperty="apidesignId">
        INSERT INTO tb_apidesign
        <trim prefix="(" suffix=")" suffixOverrides=",">
            apidesign_no, project_id, title,
            <if test="httpMethod != null">http_method,</if>
            <if test="apiPath != null">api_path,</if>
            <if test="description != null">description,</if>
            <if test="requestSchema != null">request_schema,</if>
            <if test="responseSchema != null">response_schema,</if>
            <if test="errorCodes != null">error_codes,</if>
            <if test="openapiContent != null">openapi_content,</if>
            mock_enabled, version, ai_generated, status, author_user_id,
            <if test="reviewerUserId != null">reviewer_user_id,</if>
            create_by, create_time, update_by, update_time,
            <if test="remark != null">remark,</if>
            del_flag
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            #{apidesignNo}, #{projectId}, #{title},
            <if test="httpMethod != null">#{httpMethod},</if>
            <if test="apiPath != null">#{apiPath},</if>
            <if test="description != null">#{description},</if>
            <if test="requestSchema != null">#{requestSchema},</if>
            <if test="responseSchema != null">#{responseSchema},</if>
            <if test="errorCodes != null">#{errorCodes},</if>
            <if test="openapiContent != null">#{openapiContent},</if>
            #{mockEnabled}, #{version}, #{aiGenerated}, #{status}, #{authorUserId},
            <if test="reviewerUserId != null">#{reviewerUserId},</if>
            #{createBy}, #{createTime}, #{updateBy}, #{updateTime},
            <if test="remark != null">#{remark},</if>
            '0'
        </trim>
    </insert>

    <update id="updateApidesign" parameterType="cn.com.bosssfot.dv.plm.apidesign.domain.Apidesign">
        UPDATE tb_apidesign
        <trim prefix="SET" suffixOverrides=",">
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="httpMethod != null">http_method = #{httpMethod},</if>
            <if test="apiPath != null">api_path = #{apiPath},</if>
            <if test="description != null">description = #{description},</if>
            <if test="requestSchema != null">request_schema = #{requestSchema},</if>
            <if test="responseSchema != null">response_schema = #{responseSchema},</if>
            <if test="errorCodes != null">error_codes = #{errorCodes},</if>
            <if test="openapiContent != null">openapi_content = #{openapiContent},</if>
            <if test="mockEnabled != null">mock_enabled = #{mockEnabled},</if>
            <if test="version != null">version = #{version},</if>
            <if test="reviewReport != null">review_report = #{reviewReport},</if>
            <if test="aiGenerated != null">ai_generated = #{aiGenerated},</if>
            <if test="aiGeneratedAt != null">ai_generated_at = #{aiGeneratedAt},</if>
            <if test="status != null">status = #{status},</if>
            <if test="reviewerUserId != null">reviewer_user_id = #{reviewerUserId},</if>
            update_by = #{updateBy},
            update_time = #{updateTime},
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        WHERE apidesign_id = #{apidesignId}
    </update>

    <update id="deleteApidesignByIds" parameterType="Long">
        UPDATE tb_apidesign SET del_flag = '2'
        WHERE apidesign_id IN
        <foreach collection="array" item="apidesignId" open="(" separator="," close=")">
            #{apidesignId}
        </foreach>
    </update>

</mapper>
