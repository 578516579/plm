<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.com.bosssfot.dv.plm.autotest.mapper.AutoTestMapper">

    <resultMap type="AutoTest" id="AutoTestResult">
        <result property="autotestId"             column="autotest_id"             />
        <result property="autotestNo"             column="autotest_no"             />
        <result property="projectId"              column="project_id"              />
        <result property="title"                  column="title"                   />
        <result property="testSuiteType"          column="test_suite_type"         />
        <result property="framework"              column="framework"               />
        <result property="targetUrl"              column="target_url"              />
        <result property="scriptContent"          column="script_content"          />
        <result property="scheduleEnabled"        column="schedule_enabled"        />
        <result property="scheduleCron"           column="schedule_cron"           />
        <result property="totalCases"             column="total_cases"             />
        <result property="passedCases"            column="passed_cases"            />
        <result property="failedCases"            column="failed_cases"            />
        <result property="passRate"               column="pass_rate"               />
        <result property="executionDurationSec"   column="execution_duration_sec"  />
        <result property="lastExecutedAt"         column="last_executed_at"        />
        <result property="lastRootCauseAnalysis"  column="last_root_cause_analysis"/>
        <result property="aiGenerated"            column="ai_generated"            />
        <result property="aiGeneratedAt"          column="ai_generated_at"         />
        <result property="status"                 column="status"                  />
        <result property="authorUserId"           column="author_user_id"          />
        <result property="createBy"               column="create_by"               />
        <result property="createTime"             column="create_time"             />
        <result property="updateBy"               column="update_by"               />
        <result property="updateTime"             column="update_time"             />
        <result property="remark"                 column="remark"                  />
        <result property="delFlag"                column="del_flag"                />
    </resultMap>

    <sql id="selectAutoTestVo">
        select autotest_id, autotest_no, project_id, title, test_suite_type, framework,
               target_url, script_content, schedule_enabled, schedule_cron,
               total_cases, passed_cases, failed_cases, pass_rate,
               execution_duration_sec, last_executed_at, last_root_cause_analysis,
               ai_generated, ai_generated_at, status, author_user_id,
               create_by, create_time, update_by, update_time, remark, del_flag
        from tb_autotest
    </sql>

    <select id="selectAutoTestList" parameterType="AutoTest" resultMap="AutoTestResult">
        <include refid="selectAutoTestVo"/>
        <where>
            del_flag = '0'
            <if test="autotestNo != null and autotestNo != ''">and autotest_no like concat('%', #{autotestNo}, '%')</if>
            <if test="projectId != null">and project_id = #{projectId}</if>
            <if test="title != null and title != ''">and title like concat('%', #{title}, '%')</if>
            <if test="testSuiteType != null and testSuiteType != ''">and test_suite_type = #{testSuiteType}</if>
            <if test="framework != null and framework != ''">and framework = #{framework}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectAutoTestById" parameterType="Long" resultMap="AutoTestResult">
        <include refid="selectAutoTestVo"/>
        where autotest_id = #{autotestId} and del_flag = '0'
    </select>

    <insert id="insertAutoTest" parameterType="AutoTest" useGeneratedKeys="true" keyProperty="autotestId">
        insert into tb_autotest
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="autotestNo != null">autotest_no,</if>
            <if test="projectId != null">project_id,</if>
            <if test="title != null">title,</if>
            <if test="testSuiteType != null">test_suite_type,</if>
            <if test="framework != null">framework,</if>
            <if test="targetUrl != null">target_url,</if>
            <if test="scriptContent != null">script_content,</if>
            <if test="scheduleEnabled != null">schedule_enabled,</if>
            <if test="scheduleCron != null">schedule_cron,</if>
            <if test="totalCases != null">total_cases,</if>
            <if test="passedCases != null">passed_cases,</if>
            <if test="failedCases != null">failed_cases,</if>
            <if test="passRate != null">pass_rate,</if>
            <if test="executionDurationSec != null">execution_duration_sec,</if>
            <if test="lastExecutedAt != null">last_executed_at,</if>
            <if test="lastRootCauseAnalysis != null">last_root_cause_analysis,</if>
            <if test="aiGenerated != null">ai_generated,</if>
            <if test="aiGeneratedAt != null">ai_generated_at,</if>
            <if test="status != null">status,</if>
            <if test="authorUserId != null">author_user_id,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="autotestNo != null">#{autotestNo},</if>
            <if test="projectId != null">#{projectId},</if>
            <if test="title != null">#{title},</if>
            <if test="testSuiteType != null">#{testSuiteType},</if>
            <if test="framework != null">#{framework},</if>
            <if test="targetUrl != null">#{targetUrl},</if>
            <if test="scriptContent != null">#{scriptContent},</if>
            <if test="scheduleEnabled != null">#{scheduleEnabled},</if>
            <if test="scheduleCron != null">#{scheduleCron},</if>
            <if test="totalCases != null">#{totalCases},</if>
            <if test="passedCases != null">#{passedCases},</if>
            <if test="failedCases != null">#{failedCases},</if>
            <if test="passRate != null">#{passRate},</if>
            <if test="executionDurationSec != null">#{executionDurationSec},</if>
            <if test="lastExecutedAt != null">#{lastExecutedAt},</if>
            <if test="lastRootCauseAnalysis != null">#{lastRootCauseAnalysis},</if>
            <if test="aiGenerated != null">#{aiGenerated},</if>
            <if test="aiGeneratedAt != null">#{aiGeneratedAt},</if>
            <if test="status != null">#{status},</if>
            <if test="authorUserId != null">#{authorUserId},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateAutoTest" parameterType="AutoTest">
        update tb_autotest
        <trim prefix="SET" suffixOverrides=",">
            <if test="autotestNo != null">autotest_no = #{autotestNo},</if>
            <if test="projectId != null">project_id = #{projectId},</if>
            <if test="title != null">title = #{title},</if>
            <if test="testSuiteType != null">test_suite_type = #{testSuiteType},</if>
            <if test="framework != null">framework = #{framework},</if>
            <if test="targetUrl != null">target_url = #{targetUrl},</if>
            <if test="scriptContent != null">script_content = #{scriptContent},</if>
            <if test="scheduleEnabled != null">schedule_enabled = #{scheduleEnabled},</if>
            <if test="scheduleCron != null">schedule_cron = #{scheduleCron},</if>
            <if test="totalCases != null">total_cases = #{totalCases},</if>
            <if test="passedCases != null">passed_cases = #{passedCases},</if>
            <if test="failedCases != null">failed_cases = #{failedCases},</if>
            <if test="passRate != null">pass_rate = #{passRate},</if>
            <if test="executionDurationSec != null">execution_duration_sec = #{executionDurationSec},</if>
            <if test="lastExecutedAt != null">last_executed_at = #{lastExecutedAt},</if>
            <if test="lastRootCauseAnalysis != null">last_root_cause_analysis = #{lastRootCauseAnalysis},</if>
            <if test="aiGenerated != null">ai_generated = #{aiGenerated},</if>
            <if test="aiGeneratedAt != null">ai_generated_at = #{aiGeneratedAt},</if>
            <if test="status != null">status = #{status},</if>
            <if test="authorUserId != null">author_user_id = #{authorUserId},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where autotest_id = #{autotestId}
    </update>

    <update id="deleteAutoTestByIds" parameterType="Long">
        update tb_autotest set del_flag = '2' where autotest_id in
        <foreach item="id" collection="array" open="(" separator="," close=")">#{id}</foreach>
    </update>

    <select id="selectMaxSeqOfYear" parameterType="String" resultType="java.lang.Integer">
        select max(cast(substring(autotest_no, length(#{prefix}) + 1) as unsigned)) as max_seq
        from tb_autotest
        where autotest_no like concat(#{prefix}, '%')
    </select>
</mapper>
