<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.com.bosssfot.dv.plm.autotest.mapper.AutotestMapper">

    <resultMap type="cn.com.bosssfot.dv.plm.autotest.domain.Autotest" id="AutotestResult">
        <id     property="autotestId"       column="autotest_id"/>
        <result property="autotestNo"       column="autotest_no"/>
        <result property="projectId"        column="project_id"/>
        <result property="title"            column="title"/>
        <result property="suiteType"        column="suite_type"/>
        <result property="framework"        column="framework"/>
        <result property="scriptContent"    column="script_content"/>
        <result property="lastRunAt"        column="last_run_at"/>
        <result property="lastRunResult"    column="last_run_result"/>
        <result property="passRate"         column="pass_rate"/>
        <result property="totalCases"       column="total_cases"/>
        <result property="failedCases"      column="failed_cases"/>
        <result property="executionTime"    column="execution_time"/>
        <result property="scheduleCron"     column="schedule_cron"/>
        <result property="aiGenerated"      column="ai_generated"/>
        <result property="aiGeneratedAt"    column="ai_generated_at"/>
        <result property="status"           column="status"/>
        <result property="authorUserId"     column="author_user_id"/>
        <result property="createBy"         column="create_by"/>
        <result property="createTime"       column="create_time"/>
        <result property="updateBy"         column="update_by"/>
        <result property="updateTime"       column="update_time"/>
        <result property="remark"           column="remark"/>
    </resultMap>

    <sql id="selectAutotestVo">
        SELECT autotest_id, autotest_no, project_id, title, suite_type, framework,
               script_content, last_run_at, last_run_result, pass_rate,
               total_cases, failed_cases, execution_time, schedule_cron,
               ai_generated, ai_generated_at, status, author_user_id,
               create_by, create_time, update_by, update_time, remark
        FROM tb_autotest
        WHERE del_flag = '0'
    </sql>

    <select id="selectAutotestList" parameterType="cn.com.bosssfot.dv.plm.autotest.domain.Autotest" resultMap="AutotestResult">
        <include refid="selectAutotestVo"/>
        <if test="autotestNo != null and autotestNo != ''">AND autotest_no LIKE CONCAT('%', #{autotestNo}, '%')</if>
        <if test="projectId != null">AND project_id = #{projectId}</if>
        <if test="title != null and title != ''">AND title LIKE CONCAT('%', #{title}, '%')</if>
        <if test="suiteType != null and suiteType != ''">AND suite_type = #{suiteType}</if>
        <if test="status != null and status != ''">AND status = #{status}</if>
        ORDER BY create_time DESC
    </select>

    <select id="selectAutotestById" parameterType="Long" resultMap="AutotestResult">
        <include refid="selectAutotestVo"/>
        AND autotest_id = #{autotestId}
    </select>

    <select id="selectMaxSeqOfYear" parameterType="String" resultType="Integer">
        SELECT MAX(CAST(SUBSTRING_INDEX(autotest_no, '-', -1) AS UNSIGNED))
        FROM tb_autotest
        WHERE autotest_no LIKE CONCAT(#{prefix}, '%') AND del_flag = '0'
    </select>

    <insert id="insertAutotest" parameterType="cn.com.bosssfot.dv.plm.autotest.domain.Autotest" useGeneratedKeys="true" keyProperty="autotestId">
        INSERT INTO tb_autotest
        <trim prefix="(" suffix=")" suffixOverrides=",">
            autotest_no, project_id, title,
            <if test="suiteType != null">suite_type,</if>
            <if test="framework != null">framework,</if>
            <if test="scriptContent != null">script_content,</if>
            <if test="scheduleCron != null">schedule_cron,</if>
            total_cases, failed_cases, execution_time,
            ai_generated, status, author_user_id,
            create_by, create_time, update_by, update_time,
            <if test="remark != null">remark,</if>
            del_flag
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            #{autotestNo}, #{projectId}, #{title},
            <if test="suiteType != null">#{suiteType},</if>
            <if test="framework != null">#{framework},</if>
            <if test="scriptContent != null">#{scriptContent},</if>
            <if test="scheduleCron != null">#{scheduleCron},</if>
            #{totalCases}, #{failedCases}, #{executionTime},
            #{aiGenerated}, #{status}, #{authorUserId},
            #{createBy}, #{createTime}, #{updateBy}, #{updateTime},
            <if test="remark != null">#{remark},</if>
            '0'
        </trim>
    </insert>

    <update id="updateAutotest" parameterType="cn.com.bosssfot.dv.plm.autotest.domain.Autotest">
        UPDATE tb_autotest
        <trim prefix="SET" suffixOverrides=",">
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="suiteType != null">suite_type = #{suiteType},</if>
            <if test="framework != null">framework = #{framework},</if>
            <if test="scriptContent != null">script_content = #{scriptContent},</if>
            <if test="lastRunAt != null">last_run_at = #{lastRunAt},</if>
            <if test="lastRunResult != null">last_run_result = #{lastRunResult},</if>
            <if test="passRate != null">pass_rate = #{passRate},</if>
            <if test="totalCases != null">total_cases = #{totalCases},</if>
            <if test="failedCases != null">failed_cases = #{failedCases},</if>
            <if test="executionTime != null">execution_time = #{executionTime},</if>
            <if test="scheduleCron != null">schedule_cron = #{scheduleCron},</if>
            <if test="aiGenerated != null">ai_generated = #{aiGenerated},</if>
            <if test="aiGeneratedAt != null">ai_generated_at = #{aiGeneratedAt},</if>
            <if test="status != null">status = #{status},</if>
            update_by = #{updateBy},
            update_time = #{updateTime},
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        WHERE autotest_id = #{autotestId}
    </update>

    <update id="deleteAutotestByIds" parameterType="Long">
        UPDATE tb_autotest SET del_flag = '2'
        WHERE autotest_id IN
        <foreach collection="array" item="autotestId" open="(" separator="," close=")">
            #{autotestId}
        </foreach>
    </update>

</mapper>
