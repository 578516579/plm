<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.com.bosssfot.dv.plm.dora.mapper.DoraMapper">

    <resultMap type="Dora" id="DoraResult">
        <result property="doraId"             column="dora_id"              />
        <result property="doraNo"             column="dora_no"              />
        <result property="projectId"          column="project_id"           />
        <result property="period"             column="period"               />
        <result property="deployFrequency"    column="deploy_frequency"     />
        <result property="leadTimeHours"      column="lead_time_hours"      />
        <result property="changeFailureRate"  column="change_failure_rate"  />
        <result property="mttrHours"          column="mttr_hours"           />
        <result property="doraLevel"          column="dora_level"           />
        <result property="aiSuggestions"      column="ai_suggestions"       />
        <result property="aiGenerated"        column="ai_generated"         />
        <result property="aiGeneratedAt"      column="ai_generated_at"      />
        <result property="status"             column="status"               />
        <result property="authorUserId"       column="author_user_id"       />
        <result property="createBy"           column="create_by"            />
        <result property="createTime"         column="create_time"          />
        <result property="updateBy"           column="update_by"            />
        <result property="updateTime"         column="update_time"          />
        <result property="remark"             column="remark"               />
        <result property="delFlag"            column="del_flag"             />
    </resultMap>

    <sql id="selectDoraVo">
        select dora_id, dora_no, project_id, period, deploy_frequency, lead_time_hours,
               change_failure_rate, mttr_hours, dora_level, ai_suggestions, ai_generated,
               ai_generated_at, status, author_user_id,
               create_by, create_time, update_by, update_time, remark, del_flag
        from tb_dora
    </sql>

    <select id="selectDoraList" parameterType="Dora" resultMap="DoraResult">
        <include refid="selectDoraVo"/>
        <where>
            del_flag = '0'
            <if test="doraNo != null and doraNo != ''">and dora_no like concat('%', #{doraNo}, '%')</if>
            <if test="projectId != null">and project_id = #{projectId}</if>
            <if test="period != null and period != ''">and period = #{period}</if>
            <if test="doraLevel != null and doraLevel != ''">and dora_level = #{doraLevel}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
            <if test="authorUserId != null">and author_user_id = #{authorUserId}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectDoraById" parameterType="Long" resultMap="DoraResult">
        <include refid="selectDoraVo"/>
        where dora_id = #{doraId} and del_flag = '0'
    </select>

    <insert id="insertDora" parameterType="Dora" useGeneratedKeys="true" keyProperty="doraId">
        insert into tb_dora
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="doraNo != null">dora_no,</if>
            <if test="projectId != null">project_id,</if>
            <if test="period != null">period,</if>
            <if test="deployFrequency != null">deploy_frequency,</if>
            <if test="leadTimeHours != null">lead_time_hours,</if>
            <if test="changeFailureRate != null">change_failure_rate,</if>
            <if test="mttrHours != null">mttr_hours,</if>
            <if test="doraLevel != null">dora_level,</if>
            <if test="aiSuggestions != null">ai_suggestions,</if>
            <if test="aiGenerated != null">ai_generated,</if>
            <if test="aiGeneratedAt != null">ai_generated_at,</if>
            <if test="status != null">status,</if>
            <if test="authorUserId != null">author_user_id,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            del_flag,
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="doraNo != null">#{doraNo},</if>
            <if test="projectId != null">#{projectId},</if>
            <if test="period != null">#{period},</if>
            <if test="deployFrequency != null">#{deployFrequency},</if>
            <if test="leadTimeHours != null">#{leadTimeHours},</if>
            <if test="changeFailureRate != null">#{changeFailureRate},</if>
            <if test="mttrHours != null">#{mttrHours},</if>
            <if test="doraLevel != null">#{doraLevel},</if>
            <if test="aiSuggestions != null">#{aiSuggestions},</if>
            <if test="aiGenerated != null">#{aiGenerated},</if>
            <if test="aiGeneratedAt != null">#{aiGeneratedAt},</if>
            <if test="status != null">#{status},</if>
            <if test="authorUserId != null">#{authorUserId},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            '0',
            sysdate()
        </trim>
    </insert>

    <update id="updateDora" parameterType="Dora">
        update tb_dora
        <trim prefix="SET" suffixOverrides=",">
            <if test="doraNo != null">dora_no = #{doraNo},</if>
            <if test="projectId != null">project_id = #{projectId},</if>
            <if test="period != null">period = #{period},</if>
            <if test="deployFrequency != null">deploy_frequency = #{deployFrequency},</if>
            <if test="leadTimeHours != null">lead_time_hours = #{leadTimeHours},</if>
            <if test="changeFailureRate != null">change_failure_rate = #{changeFailureRate},</if>
            <if test="mttrHours != null">mttr_hours = #{mttrHours},</if>
            <if test="doraLevel != null">dora_level = #{doraLevel},</if>
            <if test="aiSuggestions != null">ai_suggestions = #{aiSuggestions},</if>
            <if test="aiGenerated != null">ai_generated = #{aiGenerated},</if>
            <if test="aiGeneratedAt != null">ai_generated_at = #{aiGeneratedAt},</if>
            <if test="status != null">status = #{status},</if>
            <if test="authorUserId != null">author_user_id = #{authorUserId},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where dora_id = #{doraId}
    </update>

    <update id="deleteDoraByIds" parameterType="Long">
        update tb_dora set del_flag = '2' where dora_id in
        <foreach item="doraId" collection="array" open="(" separator="," close=")">
            #{doraId}
        </foreach>
    </update>

    <select id="selectMaxSeqOfYear" parameterType="String" resultType="java.lang.Integer">
        select max(cast(substring(dora_no, length(#{prefix}) + 1) as unsigned)) as max_seq
        from tb_dora
        where dora_no like concat(#{prefix}, '%')
    </select>

</mapper>
