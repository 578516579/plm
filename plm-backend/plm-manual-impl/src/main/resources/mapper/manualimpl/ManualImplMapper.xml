<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.com.bosssfot.dv.plm.manualimpl.mapper.ManualImplMapper">

    <resultMap type="cn.com.bosssfot.dv.plm.manualimpl.domain.ManualImpl" id="ManualImplResult">
        <id     property="manualimplId"   column="manualimpl_id"   />
        <result property="manualimplNo"   column="manualimpl_no"   />
        <result property="projectId"      column="project_id"      />
        <result property="title"          column="title"           />
        <result property="deployMode"     column="deploy_mode"     />
        <result property="osType"         column="os_type"         />
        <result property="dbType"         column="db_type"         />
        <result property="envConfig"      column="env_config"      />
        <result property="content"        column="content"         />
        <result property="outputFormats"  column="output_formats"  />
        <result property="aiGenerated"    column="ai_generated"    />
        <result property="generatedAt"    column="generated_at"    />
        <result property="status"         column="status"          />
        <result property="authorUserId"   column="author_user_id"  />
        <result property="createBy"       column="create_by"       />
        <result property="createTime"     column="create_time"     />
        <result property="updateBy"       column="update_by"       />
        <result property="updateTime"     column="update_time"     />
        <result property="remark"         column="remark"          />
        <result property="delFlag"        column="del_flag"        />
    </resultMap>

    <sql id="selectManualImplVo">
        select manualimpl_id, manualimpl_no, project_id, title, deploy_mode, os_type, db_type,
               env_config, content, output_formats, ai_generated, generated_at, status,
               author_user_id, create_by, create_time, update_by, update_time, remark, del_flag
        from tb_manual_impl
    </sql>

    <select id="selectManualImplList" parameterType="cn.com.bosssfot.dv.plm.manualimpl.domain.ManualImpl" resultMap="ManualImplResult">
        <include refid="selectManualImplVo"/>
        <where>
            del_flag = '0'
            <if test="manualimplNo != null and manualimplNo != ''">and manualimpl_no like concat('%', #{manualimplNo}, '%')</if>
            <if test="projectId != null">and project_id = #{projectId}</if>
            <if test="title != null and title != ''">and title like concat('%', #{title}, '%')</if>
            <if test="deployMode != null and deployMode != ''">and deploy_mode = #{deployMode}</if>
            <if test="osType != null and osType != ''">and os_type = #{osType}</if>
            <if test="dbType != null and dbType != ''">and db_type = #{dbType}</if>
            <if test="aiGenerated != null and aiGenerated != ''">and ai_generated = #{aiGenerated}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
            <if test="authorUserId != null">and author_user_id = #{authorUserId}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectManualImplById" parameterType="Long" resultMap="ManualImplResult">
        <include refid="selectManualImplVo"/>
        where manualimpl_id = #{manualimplId} and del_flag = '0'
    </select>

    <insert id="insertManualImpl" parameterType="cn.com.bosssfot.dv.plm.manualimpl.domain.ManualImpl" useGeneratedKeys="true" keyProperty="manualimplId">
        insert into tb_manual_impl
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="manualimplNo != null">manualimpl_no,</if>
            <if test="projectId != null">project_id,</if>
            <if test="title != null">title,</if>
            <if test="deployMode != null">deploy_mode,</if>
            <if test="osType != null">os_type,</if>
            <if test="dbType != null">db_type,</if>
            <if test="envConfig != null">env_config,</if>
            <if test="content != null">content,</if>
            <if test="outputFormats != null">output_formats,</if>
            <if test="aiGenerated != null">ai_generated,</if>
            <if test="generatedAt != null">generated_at,</if>
            <if test="status != null">status,</if>
            <if test="authorUserId != null">author_user_id,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="manualimplNo != null">#{manualimplNo},</if>
            <if test="projectId != null">#{projectId},</if>
            <if test="title != null">#{title},</if>
            <if test="deployMode != null">#{deployMode},</if>
            <if test="osType != null">#{osType},</if>
            <if test="dbType != null">#{dbType},</if>
            <if test="envConfig != null">#{envConfig},</if>
            <if test="content != null">#{content},</if>
            <if test="outputFormats != null">#{outputFormats},</if>
            <if test="aiGenerated != null">#{aiGenerated},</if>
            <if test="generatedAt != null">#{generatedAt},</if>
            <if test="status != null">#{status},</if>
            <if test="authorUserId != null">#{authorUserId},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateManualImpl" parameterType="cn.com.bosssfot.dv.plm.manualimpl.domain.ManualImpl">
        update tb_manual_impl
        <trim prefix="SET" suffixOverrides=",">
            <if test="manualimplNo != null">manualimpl_no = #{manualimplNo},</if>
            <if test="projectId != null">project_id = #{projectId},</if>
            <if test="title != null">title = #{title},</if>
            <if test="deployMode != null">deploy_mode = #{deployMode},</if>
            <if test="osType != null">os_type = #{osType},</if>
            <if test="dbType != null">db_type = #{dbType},</if>
            <if test="envConfig != null">env_config = #{envConfig},</if>
            <if test="content != null">content = #{content},</if>
            <if test="outputFormats != null">output_formats = #{outputFormats},</if>
            <if test="aiGenerated != null">ai_generated = #{aiGenerated},</if>
            <if test="generatedAt != null">generated_at = #{generatedAt},</if>
            <if test="status != null">status = #{status},</if>
            <if test="authorUserId != null">author_user_id = #{authorUserId},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where manualimpl_id = #{manualimplId}
    </update>

    <update id="deleteManualImplByIds" parameterType="Long">
        update tb_manual_impl set del_flag = '2' where manualimpl_id in
        <foreach item="id" collection="array" open="(" separator="," close=")">#{id}</foreach>
    </update>

    <select id="selectMaxSeqOfYear" parameterType="String" resultType="java.lang.Integer">
        select max(cast(substring(manualimpl_no, length(#{prefix}) + 1) as unsigned)) as max_seq
        from tb_manual_impl
        where manualimpl_no like concat(#{prefix}, '%')
    </select>
</mapper>
