<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.com.bosssfot.dv.plm.manualops.mapper.ManualOpsMapper">

    <resultMap type="ManualOps" id="ManualOpsResult">
        <result property="manualOpsId"      column="manual_ops_id"      />
        <result property="manualOpsNo"      column="manual_ops_no"      />
        <result property="projectId"        column="project_id"         />
        <result property="title"            column="title"              />
        <result property="monitoringPlan"   column="monitoring_plan"    />
        <result property="alertChannels"    column="alert_channels"     />
        <result property="iotDeviceTypes"   column="iot_device_types"   />
        <result property="content"          column="content"            />
        <result property="aiGenerated"      column="ai_generated"       />
        <result property="aiGeneratedAt"    column="ai_generated_at"    />
        <result property="status"           column="status"             />
        <result property="authorUserId"     column="author_user_id"     />
        <result property="reviewerUserId"   column="reviewer_user_id"   />
        <result property="createBy"         column="create_by"          />
        <result property="createTime"       column="create_time"        />
        <result property="updateBy"         column="update_by"          />
        <result property="updateTime"       column="update_time"        />
        <result property="remark"           column="remark"             />
        <result property="delFlag"          column="del_flag"           />
    </resultMap>

    <sql id="selectManualOpsVo">
        select manual_ops_id, manual_ops_no, project_id, title, monitoring_plan,
               alert_channels, iot_device_types, content, ai_generated, ai_generated_at,
               status, author_user_id, reviewer_user_id,
               create_by, create_time, update_by, update_time, remark, del_flag
        from tb_manual_ops
    </sql>

    <select id="selectManualOpsList" parameterType="ManualOps" resultMap="ManualOpsResult">
        <include refid="selectManualOpsVo"/>
        <where>
            del_flag = '0'
            <if test="manualOpsNo != null and manualOpsNo != ''">and manual_ops_no like concat('%', #{manualOpsNo}, '%')</if>
            <if test="projectId != null">and project_id = #{projectId}</if>
            <if test="title != null and title != ''">and title like concat('%', #{title}, '%')</if>
            <if test="monitoringPlan != null and monitoringPlan != ''">and monitoring_plan = #{monitoringPlan}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectManualOpsById" parameterType="Long" resultMap="ManualOpsResult">
        <include refid="selectManualOpsVo"/>
        where manual_ops_id = #{manualOpsId} and del_flag = '0'
    </select>

    <insert id="insertManualOps" parameterType="ManualOps" useGeneratedKeys="true" keyProperty="manualOpsId">
        insert into tb_manual_ops
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="manualOpsNo != null">manual_ops_no,</if>
            <if test="projectId != null">project_id,</if>
            <if test="title != null">title,</if>
            <if test="monitoringPlan != null">monitoring_plan,</if>
            <if test="alertChannels != null">alert_channels,</if>
            <if test="iotDeviceTypes != null">iot_device_types,</if>
            <if test="content != null">content,</if>
            <if test="aiGenerated != null">ai_generated,</if>
            <if test="aiGeneratedAt != null">ai_generated_at,</if>
            <if test="status != null">status,</if>
            <if test="authorUserId != null">author_user_id,</if>
            <if test="reviewerUserId != null">reviewer_user_id,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="manualOpsNo != null">#{manualOpsNo},</if>
            <if test="projectId != null">#{projectId},</if>
            <if test="title != null">#{title},</if>
            <if test="monitoringPlan != null">#{monitoringPlan},</if>
            <if test="alertChannels != null">#{alertChannels},</if>
            <if test="iotDeviceTypes != null">#{iotDeviceTypes},</if>
            <if test="content != null">#{content},</if>
            <if test="aiGenerated != null">#{aiGenerated},</if>
            <if test="aiGeneratedAt != null">#{aiGeneratedAt},</if>
            <if test="status != null">#{status},</if>
            <if test="authorUserId != null">#{authorUserId},</if>
            <if test="reviewerUserId != null">#{reviewerUserId},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateManualOps" parameterType="ManualOps">
        update tb_manual_ops
        <trim prefix="SET" suffixOverrides=",">
            <if test="manualOpsNo != null">manual_ops_no = #{manualOpsNo},</if>
            <if test="projectId != null">project_id = #{projectId},</if>
            <if test="title != null">title = #{title},</if>
            <if test="monitoringPlan != null">monitoring_plan = #{monitoringPlan},</if>
            <if test="alertChannels != null">alert_channels = #{alertChannels},</if>
            <if test="iotDeviceTypes != null">iot_device_types = #{iotDeviceTypes},</if>
            <if test="content != null">content = #{content},</if>
            <if test="aiGenerated != null">ai_generated = #{aiGenerated},</if>
            <if test="aiGeneratedAt != null">ai_generated_at = #{aiGeneratedAt},</if>
            <if test="status != null">status = #{status},</if>
            <if test="authorUserId != null">author_user_id = #{authorUserId},</if>
            <if test="reviewerUserId != null">reviewer_user_id = #{reviewerUserId},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where manual_ops_id = #{manualOpsId}
    </update>

    <update id="deleteManualOpsByIds" parameterType="Long">
        update tb_manual_ops set del_flag = '2' where manual_ops_id in
        <foreach item="id" collection="array" open="(" separator="," close=")">#{id}</foreach>
    </update>

    <select id="selectMaxSeqOfYear" parameterType="String" resultType="java.lang.Integer">
        select max(cast(substring(manual_ops_no, length(#{prefix}) + 1) as unsigned)) as max_seq
        from tb_manual_ops
        where manual_ops_no like concat(#{prefix}, '%')
    </select>

</mapper>
