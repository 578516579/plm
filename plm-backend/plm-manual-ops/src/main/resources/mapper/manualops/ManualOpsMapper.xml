<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.com.bosssfot.dv.plm.manualops.mapper.ManualOpsMapper">

    <resultMap type="cn.com.bosssfot.dv.plm.manualops.domain.ManualOps" id="ManualOpsResult">
        <id     property="manualopsId"     column="manualops_id"     />
        <result property="manualopsNo"     column="manualops_no"     />
        <result property="projectId"       column="project_id"       />
        <result property="title"           column="title"            />
        <result property="monitoringPlan"  column="monitoring_plan"  />
        <result property="alertChannels"   column="alert_channels"   />
        <result property="iotDeviceTypes"  column="iot_device_types" />
        <result property="content"         column="content"          />
        <result property="outputFormats"   column="output_formats"   />
        <result property="aiGenerated"     column="ai_generated"     />
        <result property="generatedAt"     column="generated_at"     />
        <result property="status"          column="status"           />
        <result property="authorUserId"    column="author_user_id"   />
        <result property="createBy"        column="create_by"        />
        <result property="createTime"      column="create_time"      />
        <result property="updateBy"        column="update_by"        />
        <result property="updateTime"      column="update_time"      />
        <result property="remark"          column="remark"           />
        <result property="delFlag"         column="del_flag"         />
    </resultMap>

    <sql id="selectManualOpsVo">
        select manualops_id, manualops_no, project_id, title, monitoring_plan, alert_channels,
               iot_device_types, content, output_formats, ai_generated, generated_at, status,
               author_user_id, create_by, create_time, update_by, update_time, remark, del_flag
        from tb_manual_ops
    </sql>

    <select id="selectManualOpsList" parameterType="cn.com.bosssfot.dv.plm.manualops.domain.ManualOps" resultMap="ManualOpsResult">
        <include refid="selectManualOpsVo"/>
        <where>
            del_flag = '0'
            <if test="manualopsNo != null and manualopsNo != ''">and manualops_no like concat('%', #{manualopsNo}, '%')</if>
            <if test="projectId != null">and project_id = #{projectId}</if>
            <if test="title != null and title != ''">and title like concat('%', #{title}, '%')</if>
            <if test="monitoringPlan != null and monitoringPlan != ''">and monitoring_plan = #{monitoringPlan}</if>
            <if test="aiGenerated != null and aiGenerated != ''">and ai_generated = #{aiGenerated}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
            <if test="authorUserId != null">and author_user_id = #{authorUserId}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectManualOpsById" parameterType="Long" resultMap="ManualOpsResult">
        <include refid="selectManualOpsVo"/>
        where manualops_id = #{manualopsId} and del_flag = '0'
    </select>

    <insert id="insertManualOps" parameterType="cn.com.bosssfot.dv.plm.manualops.domain.ManualOps" useGeneratedKeys="true" keyProperty="manualopsId">
        insert into tb_manual_ops
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="manualopsNo != null">manualops_no,</if>
            <if test="projectId != null">project_id,</if>
            <if test="title != null">title,</if>
            <if test="monitoringPlan != null">monitoring_plan,</if>
            <if test="alertChannels != null">alert_channels,</if>
            <if test="iotDeviceTypes != null">iot_device_types,</if>
            <if test="content != null">content,</if>
            <if test="outputFormats != null">output_formats,</if>
            <if test="aiGenerated != null">ai_generated,</if>
            <if test="generatedAt != null">generated_at,</if>
            <if test="status != null">status,</if>
            <if test="authorUserId != null">author_user_id,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="manualopsNo != null">#{manualopsNo},</if>
            <if test="projectId != null">#{projectId},</if>
            <if test="title != null">#{title},</if>
            <if test="monitoringPlan != null">#{monitoringPlan},</if>
            <if test="alertChannels != null">#{alertChannels},</if>
            <if test="iotDeviceTypes != null">#{iotDeviceTypes},</if>
            <if test="content != null">#{content},</if>
            <if test="outputFormats != null">#{outputFormats},</if>
            <if test="aiGenerated != null">#{aiGenerated},</if>
            <if test="generatedAt != null">#{generatedAt},</if>
            <if test="status != null">#{status},</if>
            <if test="authorUserId != null">#{authorUserId},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateManualOps" parameterType="cn.com.bosssfot.dv.plm.manualops.domain.ManualOps">
        update tb_manual_ops
        <trim prefix="SET" suffixOverrides=",">
            <if test="manualopsNo != null">manualops_no = #{manualopsNo},</if>
            <if test="projectId != null">project_id = #{projectId},</if>
            <if test="title != null">title = #{title},</if>
            <if test="monitoringPlan != null">monitoring_plan = #{monitoringPlan},</if>
            <if test="alertChannels != null">alert_channels = #{alertChannels},</if>
            <if test="iotDeviceTypes != null">iot_device_types = #{iotDeviceTypes},</if>
            <if test="content != null">content = #{content},</if>
            <if test="outputFormats != null">output_formats = #{outputFormats},</if>
            <if test="aiGenerated != null">ai_generated = #{aiGenerated},</if>
            <if test="generatedAt != null">generated_at = #{generatedAt},</if>
            <if test="status != null">status = #{status},</if>
            <if test="authorUserId != null">author_user_id = #{authorUserId},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where manualops_id = #{manualopsId}
    </update>

    <update id="deleteManualOpsByIds" parameterType="Long">
        update tb_manual_ops set del_flag = '2' where manualops_id in
        <foreach item="id" collection="array" open="(" separator="," close=")">#{id}</foreach>
    </update>

    <select id="selectMaxSeqOfYear" parameterType="String" resultType="java.lang.Integer">
        select max(cast(substring(manualops_no, length(#{prefix}) + 1) as unsigned)) as max_seq
        from tb_manual_ops
        where manualops_no like concat(#{prefix}, '%')
    </select>
</mapper>
