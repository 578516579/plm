<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.com.bosssfot.dv.plm.pipeline.mapper.PipelineMapper">
    <resultMap type="cn.com.bosssfot.dv.plm.pipeline.domain.Pipeline" id="PipelineResult">
        <id     property="pipelineId"     column="pipeline_id"     />
        <result property="pipelineNo"     column="pipeline_no"     />
        <result property="projectId"      column="project_id"      />
        <result property="releaseId"      column="release_id"      />
        <result property="pipelineName"   column="pipeline_name"   />
        <result property="repoName"       column="repo_name"       />
        <result property="repoBranch"     column="repo_branch"     />
        <result property="cicdTool"       column="cicd_tool"       />
        <result property="triggerType"    column="trigger_type"    />
        <result property="cronExpr"       column="cron_expr"       />
        <result property="yamlContent"    column="yaml_content"    />
        <result property="lastRunStatus"  column="last_run_status" />
        <result property="lastRunAt"      column="last_run_at"     />
        <result property="totalRuns"      column="total_runs"      />
        <result property="successCount"   column="success_count"   />
        <result property="successRate"    column="success_rate"    />
        <result property="status"         column="status"          />
        <result property="authorUserId"   column="author_user_id"  />
        <result property="createBy"       column="create_by"       />
        <result property="createTime"     column="create_time"     />
        <result property="updateBy"       column="update_by"       />
        <result property="updateTime"     column="update_time"     />
        <result property="remark"         column="remark"          />
        <result property="delFlag"        column="del_flag"        />
    </resultMap>

    <sql id="selectPipelineVo">
        select pipeline_id, pipeline_no, project_id, release_id, pipeline_name, repo_name, repo_branch,
               cicd_tool, trigger_type, cron_expr, yaml_content, last_run_status, last_run_at,
               total_runs, success_count, success_rate, status, author_user_id,
               create_by, create_time, update_by, update_time, remark, del_flag
        from tb_pipeline
    </sql>

    <select id="selectPipelineList" parameterType="cn.com.bosssfot.dv.plm.pipeline.domain.Pipeline" resultMap="PipelineResult">
        <include refid="selectPipelineVo"/>
        <where>
            del_flag = '0'
            <if test="pipelineNo != null and pipelineNo != ''">and pipeline_no like concat('%', #{pipelineNo}, '%')</if>
            <if test="projectId != null">and project_id = #{projectId}</if>
            <if test="releaseId != null">and release_id = #{releaseId}</if>
            <if test="pipelineName != null and pipelineName != ''">and pipeline_name like concat('%', #{pipelineName}, '%')</if>
            <if test="repoName != null and repoName != ''">and repo_name like concat('%', #{repoName}, '%')</if>
            <if test="cicdTool != null and cicdTool != ''">and cicd_tool = #{cicdTool}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectPipelineById" parameterType="Long" resultMap="PipelineResult">
        <include refid="selectPipelineVo"/>
        where pipeline_id = #{pipelineId} and del_flag = '0'
    </select>

    <insert id="insertPipeline" parameterType="cn.com.bosssfot.dv.plm.pipeline.domain.Pipeline" useGeneratedKeys="true" keyProperty="pipelineId">
        insert into tb_pipeline
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="pipelineNo != null">pipeline_no,</if>
            <if test="projectId != null">project_id,</if>
            <if test="releaseId != null">release_id,</if>
            <if test="pipelineName != null">pipeline_name,</if>
            <if test="repoName != null">repo_name,</if>
            <if test="repoBranch != null">repo_branch,</if>
            <if test="cicdTool != null">cicd_tool,</if>
            <if test="triggerType != null">trigger_type,</if>
            <if test="cronExpr != null">cron_expr,</if>
            <if test="yamlContent != null">yaml_content,</if>
            <if test="lastRunStatus != null">last_run_status,</if>
            <if test="lastRunAt != null">last_run_at,</if>
            <if test="totalRuns != null">total_runs,</if>
            <if test="successCount != null">success_count,</if>
            <if test="successRate != null">success_rate,</if>
            <if test="status != null">status,</if>
            <if test="authorUserId != null">author_user_id,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="pipelineNo != null">#{pipelineNo},</if>
            <if test="projectId != null">#{projectId},</if>
            <if test="releaseId != null">#{releaseId},</if>
            <if test="pipelineName != null">#{pipelineName},</if>
            <if test="repoName != null">#{repoName},</if>
            <if test="repoBranch != null">#{repoBranch},</if>
            <if test="cicdTool != null">#{cicdTool},</if>
            <if test="triggerType != null">#{triggerType},</if>
            <if test="cronExpr != null">#{cronExpr},</if>
            <if test="yamlContent != null">#{yamlContent},</if>
            <if test="lastRunStatus != null">#{lastRunStatus},</if>
            <if test="lastRunAt != null">#{lastRunAt},</if>
            <if test="totalRuns != null">#{totalRuns},</if>
            <if test="successCount != null">#{successCount},</if>
            <if test="successRate != null">#{successRate},</if>
            <if test="status != null">#{status},</if>
            <if test="authorUserId != null">#{authorUserId},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updatePipeline" parameterType="cn.com.bosssfot.dv.plm.pipeline.domain.Pipeline">
        update tb_pipeline
        <trim prefix="SET" suffixOverrides=",">
            <if test="projectId != null">project_id = #{projectId},</if>
            <if test="releaseId != null">release_id = #{releaseId},</if>
            <if test="pipelineName != null">pipeline_name = #{pipelineName},</if>
            <if test="repoName != null">repo_name = #{repoName},</if>
            <if test="repoBranch != null">repo_branch = #{repoBranch},</if>
            <if test="cicdTool != null">cicd_tool = #{cicdTool},</if>
            <if test="triggerType != null">trigger_type = #{triggerType},</if>
            <if test="cronExpr != null">cron_expr = #{cronExpr},</if>
            <if test="yamlContent != null">yaml_content = #{yamlContent},</if>
            <if test="lastRunStatus != null">last_run_status = #{lastRunStatus},</if>
            <if test="lastRunAt != null">last_run_at = #{lastRunAt},</if>
            <if test="totalRuns != null">total_runs = #{totalRuns},</if>
            <if test="successCount != null">success_count = #{successCount},</if>
            <if test="successRate != null">success_rate = #{successRate},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where pipeline_id = #{pipelineId}
    </update>

    <update id="deletePipelineByIds" parameterType="Long">
        update tb_pipeline set del_flag = '2' where pipeline_id in
        <foreach item="id" collection="array" open="(" separator="," close=")">#{id}</foreach>
    </update>

    <select id="selectMaxSeqOfYear" parameterType="String" resultType="java.lang.Integer">
        select max(cast(substring(pipeline_no, length(#{prefix}) + 1) as unsigned)) as max_seq
        from tb_pipeline where pipeline_no like concat(#{prefix}, '%')
    </select>
</mapper>
