<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.com.bosssfot.dv.plm.prd.mapper.PrdMapper">

    <resultMap type="Prd" id="PrdResult">
        <result property="prdId"              column="prd_id"              />
        <result property="prdNo"              column="prd_no"              />
        <result property="projectId"          column="project_id"          />
        <result property="title"              column="title"               />
        <result property="description"        column="description"         />
        <result property="sceneTemplate"      column="scene_template"      />
        <result property="targetUser"         column="target_user"         />
        <result property="content"            column="content"             />
        <result property="aiBackground"       column="ai_background"       />
        <result property="aiUserStories"      column="ai_user_stories"     />
        <result property="aiCoreFeatures"     column="ai_core_features"    />
        <result property="aiAcceptance"       column="ai_acceptance"       />
        <result property="completenessScore"  column="completeness_score"  />
        <result property="version"            column="version"             />
        <result property="aiGenerated"        column="ai_generated"        />
        <result property="aiGeneratedAt"      column="ai_generated_at"     />
        <result property="status"             column="status"              />
        <result property="authorUserId"       column="author_user_id"      />
        <result property="reviewerUserId"     column="reviewer_user_id"    />
        <result property="createBy"           column="create_by"           />
        <result property="createTime"         column="create_time"         />
        <result property="updateBy"           column="update_by"           />
        <result property="updateTime"         column="update_time"         />
        <result property="remark"             column="remark"              />
        <result property="delFlag"            column="del_flag"            />
    </resultMap>

    <sql id="selectPrdVo">
        select prd_id, prd_no, project_id, title, description, scene_template, target_user,
               content, ai_background, ai_user_stories, ai_core_features, ai_acceptance,
               completeness_score, version, ai_generated, ai_generated_at,
               status, author_user_id, reviewer_user_id,
               create_by, create_time, update_by, update_time, remark, del_flag
        from tb_prd
    </sql>

    <select id="selectPrdList" parameterType="Prd" resultMap="PrdResult">
        <include refid="selectPrdVo"/>
        <where>
            del_flag = '0'
            <if test="prdNo != null and prdNo != ''">and prd_no like concat('%', #{prdNo}, '%')</if>
            <if test="projectId != null">and project_id = #{projectId}</if>
            <if test="title != null and title != ''">and title like concat('%', #{title}, '%')</if>
            <if test="sceneTemplate != null and sceneTemplate != ''">and scene_template = #{sceneTemplate}</if>
            <if test="targetUser != null and targetUser != ''">and target_user = #{targetUser}</if>
            <if test="version != null and version != ''">and version = #{version}</if>
            <if test="aiGenerated != null and aiGenerated != ''">and ai_generated = #{aiGenerated}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
            <if test="authorUserId != null">and author_user_id = #{authorUserId}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectPrdById" parameterType="Long" resultMap="PrdResult">
        <include refid="selectPrdVo"/>
        where prd_id = #{prdId} and del_flag = '0'
    </select>

    <insert id="insertPrd" parameterType="Prd" useGeneratedKeys="true" keyProperty="prdId">
        insert into tb_prd
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="prdNo != null">prd_no,</if>
            <if test="projectId != null">project_id,</if>
            <if test="title != null">title,</if>
            <if test="description != null">description,</if>
            <if test="sceneTemplate != null">scene_template,</if>
            <if test="targetUser != null">target_user,</if>
            <if test="content != null">content,</if>
            <if test="aiBackground != null">ai_background,</if>
            <if test="aiUserStories != null">ai_user_stories,</if>
            <if test="aiCoreFeatures != null">ai_core_features,</if>
            <if test="aiAcceptance != null">ai_acceptance,</if>
            <if test="completenessScore != null">completeness_score,</if>
            <if test="version != null">version,</if>
            <if test="aiGenerated != null">ai_generated,</if>
            <if test="aiGeneratedAt != null">ai_generated_at,</if>
            <if test="status != null">status,</if>
            <if test="authorUserId != null">author_user_id,</if>
            <if test="reviewerUserId != null">reviewer_user_id,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="prdNo != null">#{prdNo},</if>
            <if test="projectId != null">#{projectId},</if>
            <if test="title != null">#{title},</if>
            <if test="description != null">#{description},</if>
            <if test="sceneTemplate != null">#{sceneTemplate},</if>
            <if test="targetUser != null">#{targetUser},</if>
            <if test="content != null">#{content},</if>
            <if test="aiBackground != null">#{aiBackground},</if>
            <if test="aiUserStories != null">#{aiUserStories},</if>
            <if test="aiCoreFeatures != null">#{aiCoreFeatures},</if>
            <if test="aiAcceptance != null">#{aiAcceptance},</if>
            <if test="completenessScore != null">#{completenessScore},</if>
            <if test="version != null">#{version},</if>
            <if test="aiGenerated != null">#{aiGenerated},</if>
            <if test="aiGeneratedAt != null">#{aiGeneratedAt},</if>
            <if test="status != null">#{status},</if>
            <if test="authorUserId != null">#{authorUserId},</if>
            <if test="reviewerUserId != null">#{reviewerUserId},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updatePrd" parameterType="Prd">
        update tb_prd
        <trim prefix="SET" suffixOverrides=",">
            <if test="prdNo != null">prd_no = #{prdNo},</if>
            <if test="projectId != null">project_id = #{projectId},</if>
            <if test="title != null">title = #{title},</if>
            <if test="description != null">description = #{description},</if>
            <if test="sceneTemplate != null">scene_template = #{sceneTemplate},</if>
            <if test="targetUser != null">target_user = #{targetUser},</if>
            <if test="content != null">content = #{content},</if>
            <if test="aiBackground != null">ai_background = #{aiBackground},</if>
            <if test="aiUserStories != null">ai_user_stories = #{aiUserStories},</if>
            <if test="aiCoreFeatures != null">ai_core_features = #{aiCoreFeatures},</if>
            <if test="aiAcceptance != null">ai_acceptance = #{aiAcceptance},</if>
            <if test="completenessScore != null">completeness_score = #{completenessScore},</if>
            <if test="version != null">version = #{version},</if>
            <if test="aiGenerated != null">ai_generated = #{aiGenerated},</if>
            <if test="aiGeneratedAt != null">ai_generated_at = #{aiGeneratedAt},</if>
            <if test="status != null">status = #{status},</if>
            <if test="authorUserId != null">author_user_id = #{authorUserId},</if>
            <if test="reviewerUserId != null">reviewer_user_id = #{reviewerUserId},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where prd_id = #{prdId}
    </update>

    <update id="deletePrdByIds" parameterType="Long">
        update tb_prd set del_flag = '2' where prd_id in
        <foreach item="id" collection="array" open="(" separator="," close=")">#{id}</foreach>
    </update>

    <select id="selectMaxSeqOfYear" parameterType="String" resultType="java.lang.Integer">
        select max(cast(substring(prd_no, length(#{prefix}) + 1) as unsigned)) as max_seq
        from tb_prd
        where prd_no like concat(#{prefix}, '%')
    </select>
</mapper>
