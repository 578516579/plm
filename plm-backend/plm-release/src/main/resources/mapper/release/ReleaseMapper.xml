<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.com.bosssfot.dv.plm.release.mapper.ReleaseMapper">
    <resultMap type="Release" id="ReleaseResult">
        <result property="releaseId" column="release_id" />
        <result property="releaseNo" column="release_no" />
        <result property="projectId"  column="project_id" />
        <result property="title"      column="title" />
        <result property="status"     column="status" />
        <result property="createBy"   column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy"   column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark"     column="remark" />
        <result property="delFlag"    column="del_flag" />
    </resultMap>

    <sql id="selectReleaseVo">
        select release_id, release_no, project_id, title, status,
               create_by, create_time, update_by, update_time, remark, del_flag
        from tb_release
    </sql>

    <select id="selectReleaseList" parameterType="Release" resultMap="ReleaseResult">
        <include refid="selectReleaseVo"/>
        <where>
            del_flag = '0'
            <if test="title != null and title != ''">and title like concat('%', #{title}, '%')</if>
            <if test="projectId != null">and project_id = #{projectId}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectReleaseById" parameterType="Long" resultMap="ReleaseResult">
        <include refid="selectReleaseVo"/>
        where release_id = #{releaseId} and del_flag = '0'
    </select>

    <insert id="insertRelease" parameterType="Release" useGeneratedKeys="true" keyProperty="releaseId">
        insert into tb_release (release_no, project_id, title, status, create_by, create_time)
        values (#{releaseNo}, #{projectId}, #{title}, #{status}, #{createBy}, sysdate())
    </insert>

    <update id="updateRelease" parameterType="Release">
        update tb_release set title = #{title}, status = #{status}, update_by = #{updateBy}, update_time = sysdate()
        where release_id = #{releaseId}
    </update>

    <update id="deleteReleaseByIds" parameterType="Long">
        update tb_release set del_flag = '2' where release_id in
        <foreach item="id" collection="array" open="(" separator="," close=")">#{id}</foreach>
    </update>
</mapper>
