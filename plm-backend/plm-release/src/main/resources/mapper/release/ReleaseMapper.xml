<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.com.bosssfot.dv.plm.release.mapper.ReleaseMapper">

    <resultMap type="Release" id="ReleaseResult">
        <result property="releaseId"           column="release_id"            />
        <result property="releaseNo"           column="release_no"            />
        <result property="version"             column="version"               />
        <result property="projectId"           column="project_id"            />
        <result property="sprintId"            column="sprint_id"             />
        <result property="strategy"            column="strategy"              />
        <result property="environment"         column="environment"           />
        <result property="releaseNotes"        column="release_notes"         />
        <result property="plannedAt"           column="planned_at"            />
        <result property="releasedAt"          column="released_at"           />
        <result property="rollbackAt"          column="rollback_at"           />
        <result property="rollbackReason"      column="rollback_reason"       />
        <result property="status"              column="status"                />
        <result property="aiReviewScore"       column="ai_review_score"       />
        <result property="aiReviewNotes"       column="ai_review_notes"       />
        <result property="deploymentFrequency" column="deployment_frequency"  />
        <result property="leadTimeHours"       column="lead_time_hours"       />
        <result property="mttrMinutes"         column="mttr_minutes"          />
        <result property="changeFailureRate"   column="change_failure_rate"   />
        <result property="releasedByUserId"    column="released_by_user_id"   />
        <result property="createBy"            column="create_by"             />
        <result property="createTime"          column="create_time"           />
        <result property="updateBy"            column="update_by"             />
        <result property="updateTime"          column="update_time"           />
        <result property="remark"              column="remark"                />
        <result property="delFlag"             column="del_flag"              />
    </resultMap>

    <sql id="selectReleaseVo">
        select release_id, release_no, version, project_id, sprint_id, strategy, environment,
               release_notes, planned_at, released_at, rollback_at, rollback_reason, status,
               ai_review_score, ai_review_notes,
               deployment_frequency, lead_time_hours, mttr_minutes, change_failure_rate,
               released_by_user_id,
               create_by, create_time, update_by, update_time, remark, del_flag
        from tb_release
    </sql>

    <select id="selectReleaseList" parameterType="Release" resultMap="ReleaseResult">
        <include refid="selectReleaseVo"/>
        <where>
            del_flag = '0'
            <if test="releaseNo != null and releaseNo != ''">and release_no like concat('%', #{releaseNo}, '%')</if>
            <if test="version != null and version != ''">and version like concat('%', #{version}, '%')</if>
            <if test="projectId != null">and project_id = #{projectId}</if>
            <if test="strategy != null and strategy != ''">and strategy = #{strategy}</if>
            <if test="environment != null and environment != ''">and environment = #{environment}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectReleaseById" parameterType="Long" resultMap="ReleaseResult">
        <include refid="selectReleaseVo"/>
        where release_id = #{releaseId} and del_flag = '0'
    </select>

    <insert id="insertRelease" parameterType="Release" useGeneratedKeys="true" keyProperty="releaseId">
        insert into tb_release
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="releaseNo != null">release_no,</if>
            <if test="version != null">version,</if>
            <if test="projectId != null">project_id,</if>
            <if test="sprintId != null">sprint_id,</if>
            <if test="strategy != null">strategy,</if>
            <if test="environment != null">environment,</if>
            <if test="releaseNotes != null">release_notes,</if>
            <if test="plannedAt != null">planned_at,</if>
            <if test="releasedAt != null">released_at,</if>
            <if test="rollbackAt != null">rollback_at,</if>
            <if test="rollbackReason != null">rollback_reason,</if>
            <if test="status != null">status,</if>
            <if test="aiReviewScore != null">ai_review_score,</if>
            <if test="aiReviewNotes != null">ai_review_notes,</if>
            <if test="deploymentFrequency != null">deployment_frequency,</if>
            <if test="leadTimeHours != null">lead_time_hours,</if>
            <if test="mttrMinutes != null">mttr_minutes,</if>
            <if test="changeFailureRate != null">change_failure_rate,</if>
            <if test="releasedByUserId != null">released_by_user_id,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="releaseNo != null">#{releaseNo},</if>
            <if test="version != null">#{version},</if>
            <if test="projectId != null">#{projectId},</if>
            <if test="sprintId != null">#{sprintId},</if>
            <if test="strategy != null">#{strategy},</if>
            <if test="environment != null">#{environment},</if>
            <if test="releaseNotes != null">#{releaseNotes},</if>
            <if test="plannedAt != null">#{plannedAt},</if>
            <if test="releasedAt != null">#{releasedAt},</if>
            <if test="rollbackAt != null">#{rollbackAt},</if>
            <if test="rollbackReason != null">#{rollbackReason},</if>
            <if test="status != null">#{status},</if>
            <if test="aiReviewScore != null">#{aiReviewScore},</if>
            <if test="aiReviewNotes != null">#{aiReviewNotes},</if>
            <if test="deploymentFrequency != null">#{deploymentFrequency},</if>
            <if test="leadTimeHours != null">#{leadTimeHours},</if>
            <if test="mttrMinutes != null">#{mttrMinutes},</if>
            <if test="changeFailureRate != null">#{changeFailureRate},</if>
            <if test="releasedByUserId != null">#{releasedByUserId},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateRelease" parameterType="Release">
        update tb_release
        <trim prefix="SET" suffixOverrides=",">
            <if test="releaseNo != null">release_no = #{releaseNo},</if>
            <if test="version != null">version = #{version},</if>
            <if test="projectId != null">project_id = #{projectId},</if>
            <if test="sprintId != null">sprint_id = #{sprintId},</if>
            <if test="strategy != null">strategy = #{strategy},</if>
            <if test="environment != null">environment = #{environment},</if>
            <if test="releaseNotes != null">release_notes = #{releaseNotes},</if>
            <if test="plannedAt != null">planned_at = #{plannedAt},</if>
            <if test="releasedAt != null">released_at = #{releasedAt},</if>
            <if test="rollbackAt != null">rollback_at = #{rollbackAt},</if>
            <if test="rollbackReason != null">rollback_reason = #{rollbackReason},</if>
            <if test="status != null">status = #{status},</if>
            <if test="aiReviewScore != null">ai_review_score = #{aiReviewScore},</if>
            <if test="aiReviewNotes != null">ai_review_notes = #{aiReviewNotes},</if>
            <if test="deploymentFrequency != null">deployment_frequency = #{deploymentFrequency},</if>
            <if test="leadTimeHours != null">lead_time_hours = #{leadTimeHours},</if>
            <if test="mttrMinutes != null">mttr_minutes = #{mttrMinutes},</if>
            <if test="changeFailureRate != null">change_failure_rate = #{changeFailureRate},</if>
            <if test="releasedByUserId != null">released_by_user_id = #{releasedByUserId},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where release_id = #{releaseId}
    </update>

    <update id="deleteReleaseByIds" parameterType="Long">
        update tb_release set del_flag = '2' where release_id in
        <foreach item="id" collection="array" open="(" separator="," close=")">#{id}</foreach>
    </update>

    <select id="selectMaxSeqOfYear" parameterType="String" resultType="java.lang.Integer">
        select max(cast(substring(release_no, length(#{prefix}) + 1) as unsigned)) as max_seq
        from tb_release
        where release_no like concat(#{prefix}, '%')
    </select>
</mapper>
