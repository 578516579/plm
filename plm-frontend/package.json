    "test:unit:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:smoke": "playwright test encoding.spec.ts navigation.spec.ts",
    "test:e2e:encoding": "playwright test encoding.spec.ts",
    "test:e2e:business": "playwright test project.spec.ts requirement.spec.ts sprint.spec.ts task.spec.ts",
    "test:e2e:quality": "playwright test defect.spec.ts testcase.spec.ts submission.spec.ts release.spec.ts",
    "test:e2e:docs": "playwright test document.spec.ts apidoc.spec.ts manual-product.spec.ts",
    "test:e2e:phase4": "playwright test testplan.spec.ts testreport.spec.ts submission.spec.ts",
    "test:e2e:release": "playwright test release.spec.ts",
    "test:e2e:apidoc": "playwright test apidoc.spec.ts",
    "test:e2e:manual-product": "playwright test manual-product.spec.ts",
    "test:e2e:testplan": "playwright test testplan.spec.ts",
    "test:e2e:testreport": "playwright test testreport.spec.ts",
    "test:e2e:report": "playwright show-report"
  },
  "private": true,
