# PLM k6 性能测试 — 本地环境变量
# 用法: cp local.env.example local.env, 编辑后 k6 run --env-file env/local.env scenarios/xxx.js
# local.env 已 gitignore,不会提交

# === 后端 ===
BASE_URL=http://localhost:8081

# === 登录凭据(测试账号,不要用生产密码) ===
PLM_USERNAME=admin
PLM_PASSWORD=admin123

# === 场景调参(可被脚本读到) ===
VUS=50                  # 并发虚拟用户数
DURATION=2m             # 持续时间(单位 s/m/h)
RAMP_UP=30s             # 爬坡时间
THINK_TIME=1            # 每次请求间隔(秒,模拟用户思考)

# === 报告 ===
K6_WEB_DASHBOARD=true   # k6 内置仪表盘(http://localhost:5665)
